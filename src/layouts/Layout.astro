---
import FloatingWhatsapp from "../components/FloatingWhatsapp.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Barber Karim - Salon de coiffure homme à Sfax",
  description = "Salon de coiffure homme à Sfax : coupe, taille de barbe et soin du visage par une équipe de 2 barbiers. Sans rendez-vous parfois pour nos clients réguliers.",
  ogImage = "/images/hero-barbier-coupe-cheveux.jpg",
} = Astro.props;

const SITE_URL = "https://barber-karim-sfax.vercel.app";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
    <meta property="og:title" content="Barber Karim - Salon de coiffure homme à Sfax" />
    <meta
      property="og:description"
      content="Coupe, taille de barbe et soin du visage à Sfax. Une équipe de 2 barbiers, sans rendez-vous parfois pour nos clients réguliers."
    />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <slot />

    <FloatingWhatsapp />

    <script src="/chatbot.js" is:inline defer></script>
    <script src="/apercu-bar.js" is:inline defer></script>
  </body>
</html>

<style is:global>
  :root {
    --color-ink: #15130f;
    --color-ink-soft: #221e17;
    --color-charcoal: #2b2620;
    --color-slate: #6e6759;
    --color-slate-light: #948c7a;
    --color-bone: #f4efe4;
    --color-cream: #ece4d2;
    --color-white: #ffffff;
    --color-gold: #c89b3c;
    --color-gold-deep: #9c7526;
    --color-gold-pale: #f5eacb;
    --color-line: rgba(21, 19, 15, 0.12);
    --font-display: "Plus Jakarta Sans", sans-serif;
    --font-body: "Inter", sans-serif;
    --shadow-soft: 0 10px 30px rgba(21, 19, 15, 0.1);
    --shadow-gold: 0 10px 26px rgba(200, 155, 60, 0.32);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    color: var(--color-charcoal);
    background: var(--color-white);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    display: block;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-display);
    line-height: 1.15;
    color: var(--color-ink);
  }

  a {
    color: inherit;
  }

  section {
    scroll-margin-top: 88px;
  }

  .container {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Signature "blade mark" eyebrow — a short precise cut, not a generic bullet */
  .blade-mark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gold-deep);
    margin-bottom: 14px;
  }

  .blade-mark::before {
    content: "";
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-gold);
  }

  .section-title {
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--color-ink);
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }

  .section-subtitle {
    color: var(--color-slate);
    font-size: 1rem;
    max-width: 560px;
  }

  .section {
    padding: 64px 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 999px;
    padding: 16px 28px;
    border: none;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-gold {
    background: var(--color-gold);
    color: var(--color-ink);
    box-shadow: var(--shadow-gold);
  }

  .btn-gold:hover {
    filter: brightness(1.06);
  }

  .btn-dark {
    background: var(--color-ink);
    color: var(--color-white);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-white);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
  }

  .btn-outline-dark {
    background: transparent;
    color: var(--color-ink);
    border: 1.5px solid rgba(21, 19, 15, 0.25);
  }

  .btn-whatsapp {
    background: #25d366;
    color: #fff;
  }

  @media (min-width: 720px) {
    .section-title {
      font-size: 2.4rem;
    }
    .section-subtitle {
      font-size: 1.1rem;
    }
    .section {
      padding: 96px 0;
    }
  }
</style>
