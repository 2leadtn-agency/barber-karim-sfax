---
const PHONE_DISPLAY = "+216 53 535 535";
const PHONE_TEL = "+21653535535";
const WHATSAPP_NUMBER = "21653535535";
const WHATSAPP_MESSAGE = encodeURIComponent("Bonjour, je vous contacte depuis votre site");

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/services", label: "Services" },
  { href: "/a-propos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];
---

<header class="nav" id="site-nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="Barber Karim - Accueil">
      <span class="nav-logo-mark"></span>
      <span class="nav-logo-text"><strong>BARBER</strong> KARIM</span>
    </a>

    <nav class="nav-links" aria-label="Navigation principale">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <a href={`tel:${PHONE_TEL}`} class="nav-icon-btn" aria-label="Appeler Barber Karim">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.5 21 3 13.5 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1L6.6 10.8z"
            stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
          ></path>
        </svg>
      </a>
      <a
        href={`https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MESSAGE}`}
        class="nav-icon-btn nav-whatsapp"
        aria-label="Écrire sur WhatsApp"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M16.02 3C9.4 3 4 8.4 4 15.02c0 2.36.64 4.57 1.87 6.52L4 29l7.63-1.83a11.96 11.96 0 0 0 4.4.83h.01c6.62 0 12.02-5.4 12.02-12.02C28.06 8.4 22.66 3 16.02 3z"
            fill="#25D366"
          ></path>
          <path
            d="M22.1 18.6c-.34-.17-2-1-2.3-1.1-.31-.11-.53-.17-.76.17-.22.34-.87 1.1-1.07 1.32-.2.23-.4.25-.73.08-.34-.17-1.43-.53-2.72-1.68-1-.9-1.68-2-1.88-2.34-.2-.34-.02-.52.15-.69.15-.15.34-.4.5-.6.17-.2.22-.34.34-.57.11-.23.06-.43-.03-.6-.08-.17-.76-1.85-1.05-2.53-.27-.66-.55-.57-.76-.58h-.65c-.23 0-.6.08-.91.43-.31.34-1.2 1.17-1.2 2.86s1.23 3.32 1.4 3.55c.17.23 2.42 3.7 5.87 5.19.82.35 1.46.56 1.96.72.82.26 1.57.22 2.16.13.66-.1 2-.82 2.28-1.6.28-.79.28-1.47.2-1.6-.08-.14-.31-.23-.65-.4z"
            fill="#fff"
          ></path>
        </svg>
      </a>
      <a href="/contact" class="btn btn-gold nav-cta">Nous contacter</a>

      <button class="nav-burger" id="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav-mobile" id="nav-mobile">
    {navLinks.map((link) => (
      <a href={link.href} class="nav-mobile-link">{link.label}</a>
    ))}
    <a href="/contact" class="btn btn-gold nav-mobile-cta">Nous contacter</a>
    <a href={`tel:${PHONE_TEL}`} class="nav-mobile-phone">{PHONE_DISPLAY}</a>
  </div>
</header>

<script is:inline>
  (function () {
    const nav = document.getElementById("site-nav");
    const burger = document.getElementById("nav-burger");
    const mobile = document.getElementById("nav-mobile");
    if (!nav) return;

    function onScroll() {
      if (window.scrollY > 8) {
        nav.classList.add("nav-scrolled");
      } else {
        nav.classList.remove("nav-scrolled");
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    if (burger && mobile) {
      burger.addEventListener("click", function () {
        const isOpen = mobile.classList.toggle("open");
        burger.classList.toggle("open", isOpen);
        burger.setAttribute("aria-expanded", String(isOpen));
        document.body.style.overflow = isOpen ? "hidden" : "";
      });
    }
  })();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(21, 19, 15, 0.9);
    backdrop-filter: blur(10px);
    transition: box-shadow 0.2s ease, background 0.2s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .nav-scrolled {
    background: rgba(21, 19, 15, 0.98);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 100%;
    flex-shrink: 0;
    text-decoration: none;
  }

  .nav-logo-mark {
    width: 9px;
    height: 9px;
    background: var(--color-gold);
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: 0.04em;
    color: var(--color-gold);
    white-space: nowrap;
  }

  .nav-logo-text strong {
    font-weight: 800;
    color: #fff;
  }

  .nav-links {
    display: none;
  }

  .nav-link {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.82);
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-gold);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    text-decoration: none;
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .nav-icon-btn svg {
    width: 18px;
    height: 18px;
  }

  .nav-whatsapp {
    background: #eafaf0;
  }

  .nav-whatsapp svg {
    width: 22px;
    height: 22px;
  }

  .nav-icon-btn:hover {
    transform: translateY(-2px);
  }

  .nav-cta {
    display: none;
    padding: 11px 20px;
    font-size: 0.88rem;
  }

  .nav-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.08);
    cursor: pointer;
    flex-shrink: 0;
  }

  .nav-burger span {
    display: block;
    width: 18px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .nav-burger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-burger.open span:nth-child(2) {
    opacity: 0;
  }
  .nav-burger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-mobile {
    max-height: 0;
    overflow: hidden;
    background: var(--color-ink);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    transition: max-height 0.28s ease;
    display: flex;
    flex-direction: column;
  }

  .nav-mobile.open {
    max-height: 420px;
  }

  .nav-mobile-link {
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .nav-mobile-cta {
    margin: 16px 20px 8px;
  }

  .nav-mobile-phone {
    text-align: center;
    text-decoration: none;
    font-weight: 700;
    color: var(--color-gold);
    padding: 0 20px 20px;
    font-family: var(--font-display);
  }

  @media (min-width: 640px) {
    .nav-cta {
      display: inline-flex;
    }
  }

  @media (min-width: 900px) {
    .nav-inner {
      height: 80px;
    }

    .nav-logo-text {
      font-size: 1.08rem;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 30px;
    }

    .nav-burger {
      display: none;
    }

    .nav-mobile {
      display: none;
    }
  }
</style>
