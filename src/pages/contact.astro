---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const PHONE_DISPLAY = "+216 53 535 535";
const PHONE_TEL = "+21653535535";
const WHATSAPP_NUMBER = "21653535535";
const PREFILLED_MESSAGE = "Bonjour, je vous contacte depuis votre site";
const WHATSAPP_HREF = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(PREFILLED_MESSAGE)}`;
---

<Layout
  title="Contact — Barber Karim | Salon de coiffure homme à Sfax"
  description="Contactez Barber Karim à Sfax : téléphone, WhatsApp ou formulaire. Sans rendez-vous parfois pour nos clients réguliers."
>
  <Nav />

  <main>
    <section class="page-header">
      <div class="container">
        <span class="blade-mark">Contact</span>
        <h1 class="page-title">Prenons contact</h1>
        <p class="page-subtitle">
          Appelez-nous, écrivez sur WhatsApp ou remplissez le formulaire ci-dessous. Clients
          réguliers : n'hésitez pas à passer directement, nous vous accueillons sans rendez-vous
          quand le salon le permet.
        </p>
      </div>
    </section>

    <section class="contact">
      <div class="container contact-inner">
        <div class="contact-info">
          <a href={`tel:${PHONE_TEL}`} class="phone-cta">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="24" height="24">
              <path
                d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1v3.6c0 .6-.4 1-1 1C10.6 21.1 2.9 13.4 2.9 3.7c0-.6.4-1 1-1H7.5c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1L6.6 10.8Z"
                stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
              ></path>
            </svg>
            <span>{PHONE_DISPLAY}</span>
          </a>

          <a href={WHATSAPP_HREF} target="_blank" rel="noopener noreferrer" class="btn-whatsapp-lg">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
              <path
                d="M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.3c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2Zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3.1.8.8-3-.2-.3c-.9-1.4-1.3-3-1.3-4.6C3.5 7.3 7.3 3.5 12 3.5s8.5 3.8 8.5 8.5-3.8 8.2-8.5 8.2Zm4.6-6.3c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.1.2-.3.2-.5.1-1.4-.7-2.3-1.3-3.2-2.8-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4L9.2 8.6c-.1-.2-.3-.2-.5-.2h-.4c-.2 0-.5.1-.7.3-.2.3-.9 1-.9 2.3s1 2.7 1.1 2.9c.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.7.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.3-.2-.5-.3Z"
              ></path>
            </svg>
            Écrire sur WhatsApp
          </a>

          <ul class="info-list">
            <li>
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                <path d="M12 21s-7-6.2-7-11.3A7 7 0 0 1 19 9.7C19 14.8 12 21 12 21Z" stroke="currentColor" stroke-width="1.8"></path>
                <circle cx="12" cy="9.5" r="2.4" stroke="currentColor" stroke-width="1.8"></circle>
              </svg>
              <span>Sfax, Tunisie</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"></circle>
                <path d="M12 7v5l3.5 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              <span>Horaires à confirmer — appelez-nous ou écrivez sur WhatsApp pour connaître nos disponibilités du jour.</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7"></circle>
                <path d="M12 7.5v5l3.2 1.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              <span>Sans rendez-vous parfois pour nos clients réguliers</span>
            </li>
          </ul>

          <div class="map-wrap">
            <!-- TO REPLACE : remplacer par l'adresse exacte du salon une fois communiquée par le client -->
            <iframe
              title="Zone du salon à Sfax"
              src="https://www.google.com/maps?q=Sfax,Tunisie&output=embed"
              width="100%"
              height="280"
              style="border:0"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

        <form class="contact-form" aria-label="Formulaire de contact">
          <label>
            Nom
            <input type="text" name="name" placeholder="Votre nom" required />
          </label>
          <label>
            Téléphone
            <input type="tel" name="phone" placeholder="XX XXX XXX" required />
          </label>
          <label>
            Service souhaité
            <select name="service">
              <option value="">Sélectionnez une prestation</option>
              <option value="coupe">Coupe de cheveux</option>
              <option value="barbe">Taille de barbe</option>
              <option value="soin-visage">Soin du visage</option>
              <option value="plusieurs">Plusieurs prestations</option>
            </select>
          </label>
          <label>
            Message
            <textarea name="message" rows="4" placeholder="Précisez votre demande ou le créneau souhaité"></textarea>
          </label>
          <button type="submit" class="btn-form-submit">Envoyer ma demande</button>
          <p class="form-note">Réponse rapide par téléphone ou WhatsApp.</p>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    padding: 128px 0 40px;
    background: var(--color-ink);
    color: #fff;
  }

  .page-header .blade-mark {
    color: var(--color-gold);
  }

  .page-title {
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
  }

  .page-subtitle {
    margin-top: 14px;
    max-width: 580px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1rem;
  }

  .contact {
    padding: 56px 0 80px;
  }

  .contact-inner {
    display: grid;
    gap: 40px;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .phone-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--color-gold);
    color: var(--color-ink);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.3rem;
    padding: 18px 24px;
    border-radius: 16px;
    box-shadow: var(--shadow-gold);
    transition: transform 0.15s ease;
  }

  .phone-cta:hover {
    transform: translateY(-2px);
  }

  .btn-whatsapp-lg {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 15px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-family: var(--font-display);
    font-size: 0.98rem;
    background: #25d366;
    color: #fff;
  }

  .info-list {
    list-style: none;
    margin-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .info-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.95rem;
    color: var(--color-slate);
  }

  .info-list svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-gold-deep);
  }

  .map-wrap {
    margin-top: 12px;
    border-radius: 16px;
    overflow: hidden;
    line-height: 0;
    border: 1px solid var(--color-line);
  }

  .contact-form {
    background: var(--color-white);
    color: var(--color-charcoal);
    border-radius: 18px;
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--shadow-soft);
    border: 1px solid var(--color-line);
    height: fit-content;
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 12px 14px;
    border: 1.5px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-bone);
    resize: vertical;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  .btn-form-submit {
    margin-top: 6px;
    background: var(--color-gold);
    color: var(--color-ink);
    border: none;
    padding: 15px;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.98rem;
    cursor: pointer;
    transition: filter 0.15s ease;
  }

  .btn-form-submit:hover {
    filter: brightness(1.05);
  }

  .form-note {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-slate);
  }

  @media (min-width: 720px) {
    .page-header {
      padding: 148px 0 56px;
    }
    .page-title {
      font-size: 2.6rem;
    }
    .page-subtitle {
      font-size: 1.1rem;
    }
  }

  @media (min-width: 960px) {
    .contact-inner {
      grid-template-columns: 1fr 1fr;
      gap: 60px;
    }
  }
</style>
